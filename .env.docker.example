# ── InvokeBoard — Docker environment ─────────────────────────────────
# Copy to `.env` next to docker-compose.yml and fill in real values:
#   cp .env.docker.example .env
# Both bridges read only the vars they need; extra vars are ignored.

# ── Jira — required by BOTH bridges ──────────────────────────────────────────
JIRA_BASE_URL=https://your-org.atlassian.net
JIRA_EMAIL=you@example.com
JIRA_API_TOKEN=your_atlassian_api_token

# ── Jira boards / projects — required by mcp-jira ────────────────────────────
JIRA_DEV_BOARD_ID=1234
JIRA_DEV_PROJECT_KEY=DEV
JIRA_PO_BOARD_ID=5678
JIRA_PO_PROJECT_KEY=PO

# ── Jira field mapping — optional (sensible defaults shown) ──────────────────
JIRA_STORY_POINTS_FIELD=customfield_10016
JIRA_LINK_TYPE=Relates
JIRA_FLAGGED_FIELD=
JIRA_CODE_REVIEW_STATUSES=code review,in review,peer review,review
JIRA_VELOCITY_SPRINTS=6

# ── GitHub — required by mcp-github ──────────────────────────────────────────
GITHUB_TOKEN=ghp_your_personal_access_token
GITHUB_REPO=owner/repo

# ── AI drafting — optional. Unset = disabled; the app uses deterministic
#    templates and the bridge returns 503 AI_UNAVAILABLE. ───────────────────
# AI_PROVIDER=github                  # "github" (GitHub Models) or "anthropic"
# GITHUB_MODELS_TOKEN=ghp_...         # for AI_PROVIDER=github
# GITHUB_MODELS_MODEL=openai/gpt-4o-mini
# ANTHROPIC_API_KEY=sk-ant-...        # for AI_PROVIDER=anthropic
# ANTHROPIC_MODEL=claude-opus-4-8

# ── CORS — optional ──────────────────────────────────────────────────────────
# Only needed if the BROWSER calls the bridges on a DIFFERENT origin than the
# SPA (i.e. you are NOT using the default nginx reverse-proxy — e.g. SPA on a
# CDN, bridges exposed directly). Comma-separated; "*" allows any origin.
# CORS_ORIGINS=https://your-dashboard.example.com

# ── Stores / ports — set by docker-compose.yml; override only if you must. ───
# JIRA_LEAVES_FILE=/data/.invokeboard-leaves.json
# JIRA_TEAM_FILE=/data/.invokeboard-team.json
# MCP_JIRA_HTTP_PORT=4001
# MCP_GITHUB_HTTP_PORT=4002

# ── Storage driver — optional (v1.65, ADR-077). Default "json" = today's per-file stores
#    (JIRA_LEAVES_FILE etc. above). "sqlite" moves ALL 11 stores into one database file —
#    set both and see docker-compose.yml's jira service + docs/DEPLOYMENT.md §3.3. ─────────
# STORAGE_DRIVER=sqlite
# STORAGE_SQLITE_FILE=/data/.invokeboard-stores.sqlite
