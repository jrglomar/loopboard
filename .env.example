# ──────────────────────────────────────────────────────────────
# Loopboard — root environment template (safe to commit)
# Copy to .env and fill in your values. See docs/SETUP.md.
# ──────────────────────────────────────────────────────────────

# ── Jira (required for mcp-jira) ─────────────────────────────
# Your Jira instance URL
JIRA_BASE_URL=https://yourcompany.atlassian.net
# The email tied to your Atlassian account
JIRA_EMAIL=you@company.com
# Create at https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_API_TOKEN=
# Project keys for the PO and Dev boards (Jira project settings)
JIRA_PO_PROJECT_KEY=PO
JIRA_DEV_PROJECT_KEY=DEV
# Board IDs — last number in the board URL, e.g. .../boards/10002
JIRA_PO_BOARD_ID=10001
JIRA_DEV_BOARD_ID=10002

# ── Jira tuning (optional) ───────────────────────────────────
# Story points custom field for your instance (spec §9 troubleshooting)
JIRA_STORY_POINTS_FIELD=customfield_10016
# Issue link type used to link Dev tasks to PO stories
JIRA_LINK_TYPE=Relates
# Custom field id for the "Flagged" (impediment) field, if your instance has one
JIRA_FLAGGED_FIELD=
# Status names (comma-separated, case-insensitive) that count as "Code Review"
JIRA_CODE_REVIEW_STATUSES=code review,in review,peer review,review
# How many closed sprints to average for velocity + next-sprint forecast (reports)
JIRA_VELOCITY_SPRINTS=6
# JSON file for the per-sprint leaves/offset tracker (host-local, git-ignored).
# Default: <mcp-jira package>/.loopboard-leaves.json
JIRA_LEAVES_FILE=
# JSON file for the curated per-board team roster (host-local, git-ignored).
# Default: <mcp-jira package>/.loopboard-team.json
JIRA_TEAM_FILE=
JIRA_DEV_STATUS_APP_TYPE=oAuth-com.github.integration.production

# ── GitHub (required for mcp-github, Phase 2) ────────────────
# Fine-grained PAT or classic token with repo scope
GITHUB_TOKEN=
# Default repository in owner/name form
GITHUB_REPO=your-org/your-repo

# ── HTTP bridge ports (React app ⇄ MCP servers) ──────────────
MCP_JIRA_HTTP_PORT=4001
MCP_GITHUB_HTTP_PORT=4002

# ── AI drafting in the dashboard (optional — see docs/SETUP.md) ──
# "anthropic" or "github"; leave empty to use local deterministic templates
AI_PROVIDER=
# Required when AI_PROVIDER=anthropic — https://platform.claude.com
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
# When AI_PROVIDER=github: uses GITHUB_TOKEN by default (PAT needs models:read);
# set GITHUB_MODELS_TOKEN to use a different token
GITHUB_MODELS_TOKEN=
GITHUB_MODELS_MODEL=openai/gpt-4o-mini
GITHUB_MODELS_BASE_URL=https://models.github.ai/inference

# ── Task Helper + multi-tenant (v1.44/v1.45 — see docs/CONTRACTS.md §8/§9) ──
# Both secrets below are REQUIRED to enable per-user login, connections, the
# Task Helper, and the admin console; otherwise those routes return 503.
# 32-byte base64 AES-256-GCM key. Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
TOKEN_ENC_KEY=
# HMAC secret for signing the session cookie (any long random string)
SESSION_SECRET=
# Optional user-store path (default <mcp-jira package>/.loopboard-users.json, git-ignored)
TASK_HELPER_FILE=
# Comma-separated emails granted the super-admin role at signup (board/env config + user supervision)
ADMIN_EMAILS=

CF_TUNNEL_TOKEN=