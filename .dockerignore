# Build context excludes — keep images small and reproducible.
# node_modules are reinstalled via `npm ci` inside the image.
node_modules
**/node_modules

# Build outputs
dist
**/dist
coverage
**/coverage

# Secrets & host-local state (NEVER bake into an image)
.env
.env.*
**/.env
# ALL persistent store files + per-user store dirs + the sqlite db (v1.65 hotfix). Runtime data
# must live on the /data volume (sqlite driver) — baking it in leaked a developer's local data
# into the image and made every non-leaves/team store revert on each rebuild. See ADR-077.
**/.invokeboard-*.json
**/.invokeboard-user-stores
**/.invokeboard-stores.sqlite*

# VCS / tooling / editor
.git
.gitignore
.github
.vscode
.claude
.idea

# Logs & OS cruft
*.log
**/*.log
.DS_Store
Thumbs.db

# Docs are not needed at build/runtime (keep nginx.conf — it's not .md)
*.md
docs
