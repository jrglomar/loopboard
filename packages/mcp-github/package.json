{
  "name": "@loopboard/mcp-github",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "GitHub MCP server — links pull requests to Jira tickets via MCP (stdio) and the React app (HTTP bridge)",
  "main": "src/index.ts",
  "scripts": {
    "dev": "tsx src/index.ts",
    "dev:http": "tsx watch src/http.ts",
    "start": "tsx src/index.ts",
    "start:http": "tsx src/http.ts",
    "typecheck": "tsc --noEmit",
    "build": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "axios": "^1.7.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.16.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
