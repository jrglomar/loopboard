# mcp-jira — package-level env template (safe to commit)
# Values here override the repo-root .env. Most setups only need the root .env;
# copy this file to .env if you prefer configuring the server in-package (spec §6.2).

JIRA_BASE_URL=https://yourcompany.atlassian.net
JIRA_EMAIL=you@company.com
JIRA_API_TOKEN=
JIRA_PO_PROJECT_KEY=PO
JIRA_DEV_PROJECT_KEY=DEV
JIRA_PO_BOARD_ID=10001
JIRA_DEV_BOARD_ID=10002

# Optional tuning
JIRA_STORY_POINTS_FIELD=customfield_10016
# Issue link type name (ADR-046). A PO story is linked so it "depends on" its Dev task(s).
# Must exactly match a link type in your Jira (e.g. "Depends on"); the Dev ticket goes on the
# outward side, the PO on the inward side, so it reads "PO depends on Dev".
JIRA_LINK_TYPE=Depends on
JIRA_FLAGGED_FIELD=
JIRA_CODE_REVIEW_STATUSES=code review,in review,peer review,review
JIRA_VELOCITY_SPRINTS=6
# Leaves/offset JSON store (host-local, git-ignored); default <pkg>/.loopboard-leaves.json
JIRA_LEAVES_FILE=
# Team roster JSON store (host-local, git-ignored); default <pkg>/.loopboard-team.json
JIRA_TEAM_FILE=
MCP_JIRA_HTTP_PORT=4001

# AI drafting (optional) — "anthropic" | "github" | empty = disabled
AI_PROVIDER=
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
GITHUB_MODELS_TOKEN=
GITHUB_MODELS_MODEL=openai/gpt-4o-mini
GITHUB_MODELS_BASE_URL=https://models.github.ai/inference

# Task Helper (ADR-054) — per-user accounts + encrypted Jira/GitHub connections.
# DISABLED unless BOTH secrets below are set. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"   # TOKEN_ENC_KEY
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"   # SESSION_SECRET
TOKEN_ENC_KEY=
SESSION_SECRET=
# User store JSON (host-local, git-ignored); default <pkg>/.loopboard-users.json
TASK_HELPER_FILE=